# Backend Environment Variables

# Server
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/cleaning-service
MONGODB_TEST_URI=mongodb://localhost:27017/cleaning-service-test

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@cleaningservice.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# SePay payment integration
# Bank account that receives transfers (shown on QR code)
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
# Bank code for VietQR (e.g. MB, VCB, TCB, ACB, BIDV)
SEPAY_BANK_NAME=MB
# Account holder name (shown on QR code)
SEPAY_ACCOUNT_NAME=NGUYEN VAN A
# Webhook secret — set this in SePay dashboard under "Webhook secret key"
# Use any random string, e.g.: caremate-2024-abc789xyz
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret
