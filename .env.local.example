# Backend Environment Variables (.env)

## Database Configuration
MONGODB_URI=mongodb://localhost:27017/cleaning-service
MONGODB_TEST_URI=mongodb://localhost:27017/cleaning-service-test

## Server Configuration
NODE_ENV=development
PORT=3001

## JWT Authentication
JWT_SECRET=secret-clean-key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

## Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=astersa2503@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@cleaningservice.com

## CORS Configuration
FRONTEND_URL=http://localhost:3000

## Logging
LOG_LEVEL=debug
